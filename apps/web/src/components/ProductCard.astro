---
const { title, handle } = Astro.props;
---
<article class="rounded-3xl border border-orange-200 bg-white p-6 shadow-sm">
  <div class="mb-4 flex h-40 items-center justify-center rounded-2xl bg-orange-100 text-5xl">🍪</div>
  <h2 class="font-semibold text-xl">{title}</h2>
  <a class="text-orange-700" href={`/products/${handle}`}>View product</a>
</article>
