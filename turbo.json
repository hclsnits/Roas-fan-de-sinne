{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".medusa/**", ".astro/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typegen": {
      "cache": false
    },
    "check": {}
  }
}
